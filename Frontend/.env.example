# มาตรฐานความปลอดภัยของ Vite
# Vite มีระบบป้องกันไม่ให้ค่าใน .env หลุดออกไปสุ่มสี่สุ่มห้า:
# คุณต้องขึ้นต้นชื่อตัวแปรด้วย VITE_ เสมอ (เช่น VITE_API_URL)
# ตัวแปรที่ไม่มี VITE_ นำหน้า จะไม่สามารถถูกเรียกใช้ในโค้ดฝั่ง Client ได้ เพื่อป้องกันคนแอบดู Source Code แล้วเห็นค่าสำคัญ

# API Configuration
# ชี้ไปยัง URL ของ Backend API
VITE_API_URL=http://localhost:5000/api

# App Settings
VITE_APP_NAME=Typing Game
