# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# กรณีรันผ่าน Docker ให้ใช้ mongodb://mongodb:27017/keymash
# กรณีรันข้างนอก Docker ให้ใช้ mongodb://localhost:27017/keymash
MONGO_URI=mongodb://mongodb:27017/keymash

# Security
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# CORS (ระบุ URL ของ Frontend)
FRONTEND_URL=http://localhost:5173